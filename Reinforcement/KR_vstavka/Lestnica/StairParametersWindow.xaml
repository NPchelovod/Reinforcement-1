<Window x:Class="Reinforcement.StairParametersWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Reinforcement"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Семейство направляющих колонн:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GuideColumnFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Семейство Z распорок колонн" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GuideRasporFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Семейство швеллеров косоуров:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding StringerBeamFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Семейство поддерживающих марш балок:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SupportBeamFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Семейство перил:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PerilFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Семейство ограждения:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding OgradFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Семейство пластины:" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding PlateFamily, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Толщина пластины (мм):" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding PlateThickness, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ширина лестницы (мм):" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding StairWidth, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Высота марша (мм):" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding StairHeight, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Длина марша (мм):" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding StairLength, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="Кол-во маршей, штук" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding StairNym, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>
        
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Кол-во ступеней марша, штук" VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding StupenNum, UpdateSourceTrigger=PropertyChanged}" Margin="3"/>
        
        <Button Grid.Row="13" Grid.ColumnSpan="2" Content="Создать" Command="{Binding CreateCommand}" Width="100" Height="30" Margin="10" HorizontalAlignment="Center"/>
    </Grid>
    </Window>
